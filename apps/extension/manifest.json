{
  "manifest_version": 3,
  "name": "CrossCritic",
  "version": "0.2.2",
  "description": "Archive AI chats and relay critique across providers.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_title": "CrossCritic",
    "default_icon": {
      "16": "icons/brain-16.png",
      "32": "icons/brain-32.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/brain-16.png",
    "32": "icons/brain-32.png",
    "48": "icons/brain-48.png",
    "128": "icons/brain-128.png"
  }
}
